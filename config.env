# === BASIC SETTINGS ===

# Check interval in seconds
# <0 = run once and exit
CHECK_INTERVAL=60

# Path to the file with source URLs: one URL per line
# Example:
#   https://site1.com/source1.txt
#   https://site2.com/source2.txt
#   ...
SOURCE_LIST_FILE='./files/sources.txt'

# Path to the output file
# WARNING! This file will be overwritten!
OUT_FILE='./files/out.txt'

# Additional arguments for xray-knife http
# Check ./xray-knife/xray-knife http --help
# (OUT_FILE = -o; UNITED_LINKS_FILE = -f)
XRAY_KNIFE_HTTP_ARGS=(
    -t 50
    -p
    -s
    -x txt
    -z xray
)

# Maximum number of valid nodes to write to OUT_FILE
# 0 = no limit
MAX_VALID_NODES=0

# === FLAGS (0/1) ===

# Retries fetch on network errors
NET_FAULT_TOLERANCE=1

# === OTHER SETTINGS ===

# Parent directory for the temporary directory
# Temporary directory will be created and removed on exit
TMP_PARENT_DIR='/tmp'

# Path to the lock file
# Prevents multiple script instances from running at the same time
# Usually no need to change this
LOCK_FILE='/tmp/xray-auto-sub-builder.lock'

# === BINARY PATHS ===

XRAY_KNIFE_BIN='./xray-knife/xray-knife'
